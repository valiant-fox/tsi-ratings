{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CMA assessment publish request",
  "type": "object",
  "properties": {
    "_func": {
      "type": "string",
      "const": "publish_cma_assessment"
    },
    "assessmentId": {
      "type": "number"
    }
  },
  "required": [
    "_func",
    "assessmentId"
  ],
  "additionalProperties": true
}
